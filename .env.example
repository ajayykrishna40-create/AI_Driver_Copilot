# ==========================================
# AI Driver Copilot - Environment Variables
# ==========================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual API keys and credentials
# 3. Never commit .env to Git
# ==========================================

# AWS Bedrock Configuration
BEDROCK_API_KEY=your_bedrock_api_key_here
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# Speech-to-Text (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Text-to-Speech (ElevenLabs) - Optional
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Database Configuration
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/database_name
# Example: mysql+pymysql://root:mypassword@localhost:3306/truck_assistant

# JWT Secret Key (generate a secure random string)
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Backend Settings (Optional)
# BACKEND_BASE=http://localhost:8000

# Frontend Settings (Optional)
# NEXT_PUBLIC_API_URL=http://localhost:8000
